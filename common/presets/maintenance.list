# maintenance — 自动化运维 / 网络辅助 / 远控
#
# 用途: 部署后想"丢着自动运行"的设备 (家庭主路由 / 出差备机)
# 注意: wpad-openssl 与 IB DEFAULT_PACKAGES 的 wpad-basic-* 多变体冲突 —
#       device packages.list 必须写 `-wpad-basic-mbedtls` 等排除老变体

# 证书自动签发 (ACME / Let's Encrypt)
acme
luci-app-acme

# 健康检测 (网络丢包后自动重启 / 切线路)
watchcat
luci-app-watchcat

# DDNS (动态域名)
ddns-scripts
luci-app-ddns

# 定时 Wi-Fi (按时段开关)
wifischedule
luci-app-wifischedule

# Wake-On-LAN
luci-app-wol
etherwake

# UPnP (NAT 端口自动映射)
luci-app-upnp

# IRQ 均衡 + 日志轮转
irqbalance
logrotate

# Wi-Fi 守护进程 (替换默认 wpad-basic-mbedtls, 多变体见上)
wpad-openssl
