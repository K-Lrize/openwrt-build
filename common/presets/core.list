# core — 所有路由器都要的基础包
#
# 用途: 几乎所有 devices/<dev>/packages.list 都该 @preset core
# 注意: base-config 已经 =y 的包 (luci/curl/ca-bundle 等) 不必在此重写,
#       写了也无害, 仅多一次解析

# LuCI 核心
luci
luci-base
luci-ssl
luci-mod-admin-full
luci-app-firewall
luci-app-uhttpd
luci-theme-bootstrap

# 网络基础
wget-ssl
nftables-json

# 内存压缩
zram-swap
