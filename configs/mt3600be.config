# ============================================================
# 目标设备: GL-MT3600BE (MediaTek Filogic / MT7986)
# ============================================================
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_filogic_DEVICE_glinet_gl-mt3600be=y
# ============================================================
# [1] 终端中文支持
# ============================================================
CONFIG_BUILD_NLS=y
CONFIG_BUSYBOX_CUSTOM=y
CONFIG_BUSYBOX_CONFIG_LOCALE_SUPPORT=y
CONFIG_PACKAGE_bash=y
# ============================================================
# [2] Wi-Fi — wpad-openssl（全功能：WPA3/802.11r/EAP/OWE）
# 以下三行明确禁用其他 wpad 变体，防止包冲突
# ============================================================
# CONFIG_PACKAGE_wpad-basic-mbedtls is not set
# CONFIG_PACKAGE_wpad-basic-wolfssl is not set
# CONFIG_PACKAGE_wpad-basic is not set
CONFIG_PACKAGE_wpad-openssl=y
CONFIG_PACKAGE_travelmate=y
CONFIG_PACKAGE_luci-app-travelmate=y
# ============================================================
# [3] 透明代理内核依赖 (fw4 / nftables)
# ============================================================
CONFIG_PACKAGE_kmod-nft-tproxy=y
CONFIG_PACKAGE_kmod-nft-socket=y
CONFIG_PACKAGE_kmod-nft-nat=y
CONFIG_PACKAGE_kmod-nft-fib=y
CONFIG_PACKAGE_kmod-nf-conntrack=y
CONFIG_PACKAGE_kmod-nf-nat=y
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_kmod-wireguard=y
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_nftables-json=y
# kmod-nf-flow: 内核流表加速，硬件 NAT 的基础模块
CONFIG_PACKAGE_kmod-nf-flow=y
# ============================================================
# [4] sing-box 全特性
# ============================================================
CONFIG_PACKAGE_sing-box=y
CONFIG_SING_BOX_BUILD_QUIC=y
CONFIG_SING_BOX_BUILD_UTLS=y
CONFIG_SING_BOX_BUILD_WIREGUARD=y
CONFIG_SING_BOX_BUILD_CLASH_API=y
CONFIG_SING_BOX_BUILD_DHCP=y
CONFIG_SING_BOX_BUILD_ACME=y
CONFIG_SING_BOX_BUILD_GRPC=y
CONFIG_SING_BOX_BUILD_GVISOR=y
CONFIG_SING_BOX_BUILD_TAILSCALE=y
CONFIG_SING_BOX_BUILD_V2RAY_API=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_ca-bundle=y
# ============================================================
# [5] 手机 USB 共享上网
# ============================================================
CONFIG_PACKAGE_kmod-usb-net=y
CONFIG_PACKAGE_kmod-usb-net-rndis=y
# kmod-usb-net-cdc-ncm: Android NCM 模式，比 RNDIS 快 30-40%
CONFIG_PACKAGE_kmod-usb-net-cdc-ncm=y
CONFIG_PACKAGE_kmod-usb-net-cdc-ether=y
CONFIG_PACKAGE_kmod-usb-net-ipheth=y
CONFIG_PACKAGE_libimobiledevice=y
CONFIG_PACKAGE_usbutils=y
# ============================================================
# [6] 4G/5G Modem 拨号
# ============================================================
CONFIG_PACKAGE_modemmanager=y
CONFIG_PACKAGE_luci-proto-modemmanager=y
CONFIG_PACKAGE_usb-modeswitch=y
CONFIG_PACKAGE_kmod-usb-net-qmi-wwan=y
CONFIG_PACKAGE_kmod-usb-net-cdc-mbim=y
CONFIG_PACKAGE_kmod-usb-serial-option=y
CONFIG_PACKAGE_libqmi=y
CONFIG_PACKAGE_libmbim=y
# ============================================================
# [7] USB 存储 + NAS
# ============================================================
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-extras=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-exfat=y
# kmod-fs-ntfs3: 内核原生 NTFS 驱动，性能是 ntfs-3g 的 2-3 倍
CONFIG_PACKAGE_kmod-fs-ntfs3=y
# CONFIG_PACKAGE_ntfs-3g is not set
CONFIG_PACKAGE_e2fsprogs=y
CONFIG_PACKAGE_samba4-server=y
CONFIG_PACKAGE_luci-app-samba4=y
CONFIG_PACKAGE_luci-app-hd-idle=y
CONFIG_PACKAGE_smartmontools=y
# ============================================================
# [8] WireGuard 独立 VPN
# ============================================================
CONFIG_PACKAGE_wireguard-tools=y
CONFIG_PACKAGE_luci-proto-wireguard=y
# ============================================================
# [9] QoS + 流量监控
# ============================================================
CONFIG_PACKAGE_kmod-sched-cake=y
CONFIG_PACKAGE_kmod-sched-core=y
CONFIG_PACKAGE_kmod-ifb=y
CONFIG_PACKAGE_sqm-scripts=y
CONFIG_PACKAGE_luci-app-sqm=y
CONFIG_PACKAGE_nlbwmon=y
CONFIG_PACKAGE_luci-app-nlbwmon=y
# ============================================================
# [10] AdGuard Home
# ============================================================
CONFIG_PACKAGE_adguardhome=y
CONFIG_PACKAGE_luci-app-adguardhome=y
# ============================================================
# [11] SmartDNS（DNS 并发测速，配合 AdGuard Home 实验）
# ============================================================
CONFIG_PACKAGE_smartdns=y
CONFIG_PACKAGE_luci-app-smartdns=y
# ============================================================
# [12] IPv6
# ============================================================
CONFIG_PACKAGE_kmod-ip6tables=y
CONFIG_PACKAGE_kmod-nf-reject6=y
CONFIG_PACKAGE_kmod-ip6-tunnel=y
CONFIG_PACKAGE_odhcp6c=y
CONFIG_PACKAGE_odhcpd-ipv6only=y
# ============================================================
# [13] 实用工具
# ============================================================
CONFIG_PACKAGE_watchcat=y
CONFIG_PACKAGE_luci-app-watchcat=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_ttyd=y
CONFIG_PACKAGE_luci-app-wol=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-ddns=y
CONFIG_PACKAGE_ddns-scripts=y
CONFIG_PACKAGE_zram-swap=y
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_iperf3=y
CONFIG_PACKAGE_openssh-sftp-server=y
CONFIG_PACKAGE_lsblk=y
CONFIG_PACKAGE_fdisk=y
# irqbalance: MT7986 双核中断均衡，高流量场景 CPU 更均匀
CONFIG_PACKAGE_irqbalance=y
# htop: 可交互进程监控（约 70KB，不重）
CONFIG_PACKAGE_htop=y
# tcpdump: 抓包排障，透明代理调试必备
CONFIG_PACKAGE_tcpdump=y
# conntrack-tools: 查看/管理连接跟踪表，TPROXY 调试核心
CONFIG_PACKAGE_conntrack=y
# mtr: traceroute+ping 合体，路径诊断利器
CONFIG_PACKAGE_mtr-json=y
# bind-dig: DNS 查询调试
CONFIG_PACKAGE_bind-dig=y
# nmap: 局域网扫描、端口探测
CONFIG_PACKAGE_nmap=y
# socat: 端口转发、调试，比 netcat 强
CONFIG_PACKAGE_socat=y
# strace: 跟踪系统调用，sing-box 崩溃时定位 bug 必备
CONFIG_PACKAGE_strace=y
# fail2ban: SSH 暴力破解防护，路由器暴露公网时必备
CONFIG_PACKAGE_fail2ban=y
# luci-app-statistics + collectd: Web UI 历史图表
CONFIG_PACKAGE_luci-app-statistics=y
CONFIG_PACKAGE_collectd=y
CONFIG_PACKAGE_collectd-mod-cpu=y
CONFIG_PACKAGE_collectd-mod-interface=y
CONFIG_PACKAGE_collectd-mod-load=y
CONFIG_PACKAGE_collectd-mod-memory=y
CONFIG_PACKAGE_collectd-mod-network=y
# prometheus-node-exporter-lua: 轻量 metrics 暴露（约 80KB），配合 Mac mini 上的 Grafana
CONFIG_PACKAGE_prometheus-node-exporter-lua=y
# logrotate: 防止日志撑满 tmpfs
CONFIG_PACKAGE_logrotate=y
# ============================================================
# [14] LuCI 基础框架
# ============================================================
CONFIG_LUCI_LANG_zh_Hans=y
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_luci-theme-bootstrap=y
CONFIG_PACKAGE_luci-app-firewall=y
