# GL.iNet GL-MT3600BE (MT7988 + MT7990 Wi-Fi 7)
#
# 单一事实源 — 同一份 .config 喂两条链路:
#   1. firmware.yml (IB 主轨, 90% 路径):
#        - 注释 # ib-url / # sdk-url        → fetch IB / SDK tar
#        - CONFIG_TARGET_*_DEVICE_*=y       → IB make image PROFILE=
#        - CONFIG_PACKAGE_xxx=y/m           → IB make image PACKAGES="+xxx ..."
#        - # CONFIG_PACKAGE_xxx is not set  → IB make image PACKAGES="-xxx ..."
#        - 整份 cat 进 SDK .config 编 feeds/local
#          (CONFIG_SING_BOX_WITH_* 子选项在此生效, 出自维护 sing-box.apk
#           prepend 到 IB repositories 头部, IB 装我们的版本)
#        - 其他 (CONFIG_DEVEL/CONFIG_IB/CONFIG_LUCI_LANG_*) IB 阶段 defconfig 丢弃
#   2. firmware-full.yml (救援轨): 直接 cp 进 buildroot/.config → make defconfig + make

# arch: aarch64_cortex-a53
# ib-url:  https://downloads.openwrt.org/snapshots/targets/mediatek/filogic/openwrt-imagebuilder-mediatek-filogic.Linux-x86_64.tar.zst
# sdk-url: https://downloads.openwrt.org/snapshots/targets/mediatek/filogic/openwrt-sdk-mediatek-filogic_gcc-14.3.0_musl.Linux-x86_64.tar.zst

# ============================================================
# [0] Target & Buildroot 全局开关
# ============================================================
# 全局开关只对全量 buildroot 生效, IB 阶段 defconfig 自动丢弃
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_filogic_DEVICE_glinet_gl-mt3600be=y

CONFIG_DEVEL=y
CONFIG_ALL_KMODS=y
CONFIG_SDK=y
CONFIG_IB=y
CONFIG_IB_STANDALONE=y

# ============================================================
# [1] LuCI 界面与语言
# ============================================================
CONFIG_LUCI_LANG_zh_Hans=y
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-ssl=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-app-uhttpd=y
CONFIG_PACKAGE_luci-theme-bootstrap=y

# ============================================================
# [2] 网络协议栈 (用户态)
# ============================================================
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_nftables-json=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_wget-ssl=y
# dnsmasq-full 替代默认 dnsmasq
CONFIG_PACKAGE_dnsmasq-full=y
# CONFIG_PACKAGE_dnsmasq is not set

# IPv6
CONFIG_PACKAGE_odhcp6c=y
CONFIG_PACKAGE_odhcpd-ipv6only=y

# WireGuard
CONFIG_PACKAGE_wireguard-tools=y
CONFIG_PACKAGE_luci-proto-wireguard=y

# ============================================================
# [3] 内核网络模块 (kmod-*)
# IB 阶段必须显式 +kmod-*. sing-box / sqm-scripts 等用户态包仅 declare 部分
# kmod 为 DEPENDS, 其余 (tproxy / BBR / IPv6 防火墙 / nf-flow) 必须手列.
# 全量 buildroot 阶段也照样按 =y 走.
# ============================================================
# nftables 扩展 (sing-box tproxy 模式必需)
CONFIG_PACKAGE_kmod-nft-tproxy=y
CONFIG_PACKAGE_kmod-nft-socket=y
CONFIG_PACKAGE_kmod-nft-nat=y
CONFIG_PACKAGE_kmod-nft-fib=y
CONFIG_PACKAGE_kmod-nf-conntrack=y
CONFIG_PACKAGE_kmod-nf-nat=y
CONFIG_PACKAGE_kmod-nf-flow=y

# 隧道 (sing-box GVISOR DEPENDS 已含, 这里 explicit 兜底)
CONFIG_PACKAGE_kmod-tun=y

# IPv6 防火墙
CONFIG_PACKAGE_kmod-ip6tables=y
CONFIG_PACKAGE_kmod-nf-reject6=y
CONFIG_PACKAGE_kmod-ip6-tunnel=y

# 拥塞控制 (BBR sysctl 路径无用户态包 declare, 必须显式)
CONFIG_PACKAGE_kmod-tcp-bbr=y

# QoS / SQM (sched 框架 + cake + ifb)
CONFIG_PACKAGE_kmod-sched=y
CONFIG_PACKAGE_kmod-sched-core=y
CONFIG_PACKAGE_kmod-sched-cake=y
CONFIG_PACKAGE_kmod-ifb=y

# USB 总线 + 存储
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-storage=y

# USB 网络 (4G/5G modem + iPhone tethering)
CONFIG_PACKAGE_kmod-usb-net=y
CONFIG_PACKAGE_kmod-usb-net-rndis=y
CONFIG_PACKAGE_kmod-usb-net-cdc-ncm=y
CONFIG_PACKAGE_kmod-usb-net-cdc-ether=y
CONFIG_PACKAGE_kmod-usb-net-ipheth=y
CONFIG_PACKAGE_kmod-usb-net-qmi-wwan=y
CONFIG_PACKAGE_kmod-usb-net-cdc-mbim=y
CONFIG_PACKAGE_kmod-usb-serial-option=y

# PPPoE
CONFIG_PACKAGE_kmod-ppp=y
CONFIG_PACKAGE_kmod-pppoe=y
CONFIG_PACKAGE_kmod-pppox=y
CONFIG_PACKAGE_ppp=y
CONFIG_PACKAGE_ppp-mod-pppoe=y

# 字符集 + rootfs
CONFIG_PACKAGE_kmod-nls-utf8=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_e2fsprogs=y

# ============================================================
# [4] Wi-Fi 守护进程 (multi-variant: wpad-openssl, 排除其他)
# ============================================================
CONFIG_PACKAGE_wpad-openssl=y
# CONFIG_PACKAGE_wpad-basic is not set
# CONFIG_PACKAGE_wpad-basic-mbedtls is not set
# CONFIG_PACKAGE_wpad-basic-wolfssl is not set
# CONFIG_PACKAGE_wpad-mbedtls is not set
# CONFIG_PACKAGE_wpad-wolfssl is not set

# ============================================================
# [5] 移动网络 (4G/5G modem + iPhone tethering)
# ============================================================
CONFIG_PACKAGE_modemmanager=y
CONFIG_PACKAGE_luci-proto-modemmanager=y
CONFIG_PACKAGE_usb-modeswitch=y
CONFIG_PACKAGE_libqmi=y
CONFIG_PACKAGE_libmbim=y
CONFIG_PACKAGE_libimobiledevice=y
CONFIG_PACKAGE_usbutils=y

# ============================================================
# [6] DNS / 防火墙 / QoS
# ============================================================
CONFIG_PACKAGE_smartdns=y
CONFIG_PACKAGE_luci-app-smartdns=y
CONFIG_PACKAGE_banip=y
CONFIG_PACKAGE_luci-app-banip=y
CONFIG_PACKAGE_sqm-scripts=y
CONFIG_PACKAGE_luci-app-sqm=y
CONFIG_PACKAGE_conntrack=y

# ============================================================
# [7] 运维自动化 (ACME / DDNS / WoL / 定时任务)
# ============================================================
CONFIG_PACKAGE_acme-common=y
CONFIG_PACKAGE_acme-acmesh=y
CONFIG_PACKAGE_luci-app-acme=y
CONFIG_PACKAGE_watchcat=y
CONFIG_PACKAGE_luci-app-watchcat=y
CONFIG_PACKAGE_ddns-scripts=y
CONFIG_PACKAGE_luci-app-ddns=y
CONFIG_PACKAGE_wifischedule=y
CONFIG_PACKAGE_luci-app-wifischedule=y
CONFIG_PACKAGE_luci-app-wol=y
CONFIG_PACKAGE_etherwake=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_irqbalance=y
CONFIG_PACKAGE_logrotate=y

# ============================================================
# [8] 监控 (流量统计 + Prometheus)
# ============================================================
CONFIG_PACKAGE_nlbwmon=y
CONFIG_PACKAGE_luci-app-nlbwmon=y
CONFIG_PACKAGE_prometheus-node-exporter-lua=y

# ============================================================
# [9] 终端环境与诊断
# ============================================================
CONFIG_PACKAGE_zsh=y
CONFIG_PACKAGE_vim-full=y
CONFIG_PACKAGE_tmux=y
CONFIG_PACKAGE_jq=y
CONFIG_PACKAGE_ncdu=y
CONFIG_PACKAGE_lsof=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_tcpdump=y
CONFIG_PACKAGE_socat=y
CONFIG_PACKAGE_drill=y
CONFIG_PACKAGE_iperf3=y
CONFIG_PACKAGE_git=y
CONFIG_PACKAGE_git-http=y
CONFIG_PACKAGE_rsync=y
CONFIG_PACKAGE_openssh-sftp-server=y
CONFIG_PACKAGE_zram-swap=y

# ============================================================
# [10] sing-box (自维护包 feeds/local/sing-box, IB 主轨 SDK 编)
#
# WITH_* 子选项必须显式 — 多数 feature 在 Makefile 里 default n
# (DHCP / ACME / TAILSCALE / NAIVE / V2RAY_API / CLOUDFLARED).
# IB 路径下: cat 这份 .config 进 SDK .config → make defconfig → 编 sing-box.apk
#            带这些 feature → prepend 到 IB repositories 头部 → IB 装我们的版本.
# ============================================================
CONFIG_PACKAGE_sing-box=y
CONFIG_SING_BOX_WITH_QUIC=y
CONFIG_SING_BOX_WITH_UTLS=y
CONFIG_SING_BOX_WITH_GVISOR=y
CONFIG_SING_BOX_WITH_WIREGUARD=y
CONFIG_SING_BOX_WITH_CLASH_API=y
CONFIG_SING_BOX_WITH_DHCP=y
CONFIG_SING_BOX_WITH_GRPC=y
CONFIG_SING_BOX_WITH_ACME=y
CONFIG_SING_BOX_WITH_TAILSCALE=y
# CONFIG_SING_BOX_WITH_NAIVE is not set
# CONFIG_SING_BOX_WITH_V2RAY_API is not set
# CONFIG_SING_BOX_WITH_CLOUDFLARED is not set
